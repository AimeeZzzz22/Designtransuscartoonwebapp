# Required: Google Gemini API Key
# Get from: https://ai.google.dev/
GEMINI_API_KEY=your_gemini_api_key_here

# Required: Database connection
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/transus

# Required: WeChat verification token (you create this - any random string)
# Set the same token in WeChat Official Account platform
WECHAT_TOKEN=your_random_token_here

# Optional: WeChat App credentials (for advanced features like access tokens)
WECHAT_APP_ID=your_wechat_app_id
WECHAT_APP_SECRET=your_wechat_app_secret

# Optional: Rate limiting and performance tuning
WECHAT_RATE_LIMIT_PER_MIN=30
WECHAT_CONTEXT_WINDOW_SIZE=12
WECHAT_AI_TIMEOUT_MS=1800

# Optional: Server port
PORT=8080